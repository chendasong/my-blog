# 改完 .env 后：本地请重启 `npm run dev`；线上请重新 `npm run build` 并部署新 dist。
# （Vite 在编译期注入环境变量，与浏览器清缓存无关。）
#
# ========== Supabase（沿用原有）==========
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ========== 七牛云 ==========
# 切勿把 SecretKey 写成 VITE_ 前缀，否则会被打进前端包泄露。
# 在 Vercel：Project Settings → Environment Variables 填写 QINIU_*（与下方服务端一致）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# 公开访问域名，无尾斜杠；建议带协议，例如 http://你的绑定域名（无证书）或 https://（有证书）
# 只写域名时默认自动补 http://；若已上 HTTPS 请写完整 https://
QINIU_PUBLIC_BASE=
# 存储区域：z0 华东 z1 华北 z2 华南 na0 北美 as0 新加坡（删除接口依赖）
QINIU_ZONE=z0

# 随机长串；删除与「外链转存七牛」接口（api/qiniu-fetch-upload）必配。前端请求头与之一致（见下方 VITE_）
QINIU_ADMIN_SECRET=

# 可选：与 QINIU_PUBLIC_BASE 二选一即可（vite 会把无 VITE_ 的 QINIU_PUBLIC_BASE 合并进前端）
VITE_QINIU_PUBLIC_BASE=
# 可选：与 QINIU_ADMIN_SECRET 二选一即可（会打进前端包，仅用于调用本站 /api/*）
VITE_QINIU_ADMIN_SECRET=

# 本地 vite 与 API 不同源时填写；可与 API_BASE 二选一（vite 会合并进 VITE_API_BASE）
# 留空时请求同源 /api/*，由 Vite 开发服务器挂载 api/qiniu-*.js 并自动加载 .env 中的 QINIU_*
# 生产部署在同域可留空
VITE_API_BASE=
# API_BASE=

# ========== 火山方舟（生图 / 视频等，按需填写）==========
# VITE_VOLCANO_KEY=
# 视频生成作坊：与方舟控制台模型接入点 ID 一致（首尾帧 + 中间参考图适合 Seedance 1.5 Pro 等）
# 例：VITE_VOLCANO_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
# VITE_VOLCANO_VIDEO_MODEL=
