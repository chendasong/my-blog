# ========== Supabase（沿用原有）==========
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ========== 七牛云 ==========
# 切勿把 SecretKey 写成 VITE_ 前缀，否则会被打进前端包泄露。
# 在 Vercel：Project Settings → Environment Variables 填写 QINIU_*（与下方服务端一致）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# 公开访问域名，无尾斜杠，与七牛控制台绑定域名一致
QINIU_PUBLIC_BASE=
# 存储区域：z0 华东 z1 华北 z2 华南 na0 北美 as0 新加坡（删除接口依赖）
QINIU_ZONE=z0

# 随机长串；删除接口必配。需与前端 VITE_QINIU_ADMIN_SECRET 完全一致
QINIU_ADMIN_SECRET=

# 前端可读（会进打包）：与 QINIU_PUBLIC_BASE 相同即可；用于判断 URL 是否七牛、调用删除 API
VITE_QINIU_PUBLIC_BASE=
VITE_QINIU_ADMIN_SECRET=

# 本地 vite 与 API 不同源时，填 Vercel 预览地址，例如 https://xxx.vercel.app（勿尾斜杠）
# 生产部署在同域可留空
VITE_API_BASE=
