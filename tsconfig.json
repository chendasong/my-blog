{
  "compilerOptions": {
    // 编译输出所针对的 ECMAScript 版本；决定语法降级范围（由 Vite/esbuild 再打包）
    "target": "ES2020",
    // 类字段按 ES 标准用 Object.defineProperty 语义，与原生 class 行为一致
    "useDefineForClassFields": true,
    // 类型检查时假定可用的内置库：ES2020 API + 浏览器 DOM + 可迭代 DOM 集合
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    // 自动并入的全局类型包；不写则默认包含 node_modules/@types 下全部，这里收窄为 Vite 与 Vue
    "types": ["vite/client", "vue"],
    // 模块语法采用最新 ES 模块，具体打包由构建工具处理
    "module": "ESNext",
    // 跳过对 .d.ts 声明文件的类型检查，加快编译、避免第三方声明冲突
    "skipLibCheck": true,
    // 按打包器（Vite）方式解析 import，支持 package.json exports 等
    "moduleResolution": "bundler",
    // 允许 import 路径带 .ts 等扩展名（与 Vite 一致）
    "allowImportingTsExtensions": true,
    // 允许 import JSON 并得到类型推断
    "resolveJsonModule": true,
    // 每个文件可单独转译（如 Babel/esbuild），禁止需跨文件才能理解的语法
    "isolatedModules": true,
    // 只做类型检查、不输出 .js（由 Vite 负责构建产物）
    "noEmit": true,
    // 保留 JSX 原样交给后续步骤（Vue 里多为 SFC 相关）
    "jsx": "preserve",
    // 开启严格模式全家桶（strictNullChecks、noImplicitAny 等）
    "strict": true,
    // 未使用的局部变量报错
    "noUnusedLocals": true,
    // 未使用的函数参数报错（常用于必须保留签名的回调参数时可用 _ 前缀规避）
    "noUnusedParameters": true,
    // switch 的 case 禁止穿透到下一 case，除非显式写 break/return
    "noFallthroughCasesInSwitch": true,
    // 解析非相对路径模块时的根目录（配合 paths 使用）
    "baseUrl": ".",
    // 路径别名：@/ 映射到 src/
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
